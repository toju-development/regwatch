{
  "name": "regwatch",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@regwatch/web",
    "db:generate": "pnpm -F @regwatch/db db:generate",
    "db:migrate": "pnpm -F @regwatch/db db:migrate",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "5.7.2",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-next": "15.1.0",
    "@next/eslint-plugin-next": "15.1.0",
    "eslint-plugin-tailwindcss": "4.0.0-alpha.2",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "vitest": "^2.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
