PORT=3001
DATABASE_URL=postgresql://regwatch:regwatch@localhost:5432/regwatch

# --- Invitations (sdd/org-invitations) ---
# Days before a PENDING invitation expires. Must be a positive integer
# (no units, no decimals). Falls back to 7 when unset; a malformed value
# fails fast at boot via InvitationsStartupValidator.
INVITATION_TTL_DAYS=7

# Public base URL of the WEB app — NOT the API. Used to build the
# acceptUrl on the invitation.created event (e.g. ${WEB_URL}/accept/:token).
# REQUIRED in production; in dev/test falls back to http://localhost:3000.
WEB_URL=http://localhost:3000

# Email transport for the invitation.created listener. `memory` collects
# emails in an in-process array (used by tests + local dev preview UI);
# real transports land in a later batch.
EMAIL_TRANSPORT=memory
