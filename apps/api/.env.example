# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001

# ── Base de datos ─────────────────────────────────────────────────────────────
# Mismo valor que apps/web
DATABASE_URL=postgresql://postgres:root@localhost:5432/regwatch_dev

# ── Auth — secreto compartido ─────────────────────────────────────────────────
# Mínimo 32 chars. Mismo valor que apps/web. Generar: openssl rand -base64 32
AUTH_SECRET=dev-auth-secret-local-replace-in-production-32c

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública de apps/web — usada para deep-links en notificaciones Slack
APP_URL=http://localhost:3000
# URL base de apps/web — usada para construir links de invitación por email
WEB_URL=http://localhost:3000

# ── Comunicación interna — Scanner ────────────────────────────────────────────
SCANNER_INTERNAL_URL=http://localhost:3002
SCANNER_INTERNAL_SECRET=dev-internal-secret

# ── Feature flags ─────────────────────────────────────────────────────────────
MANUAL_INGEST_ENABLED=false
EMAIL_INBOUND_ENABLED=false
# EMAIL_INBOUND_WEBHOOK_SECRET=your-sendgrid-ecdsa-key   # requerido si EMAIL_INBOUND_ENABLED=true

# ── Invitaciones ──────────────────────────────────────────────────────────────
INVITATION_TTL_DAYS=7

# ── Email outbound — notificaciones e invitaciones ────────────────────────────
# NOTA: independiente de AUTH_RESEND_KEY de apps/web (que es solo para magic link)
# memory = sin envío real, inbox en RAM (dev/CI)
# resend = envío real (requiere RESEND_API_KEY + RESEND_FROM_EMAIL)
EMAIL_TRANSPORT=memory

# Requeridas cuando EMAIL_TRANSPORT=resend
# Obtener en: https://resend.com → API Keys
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Stripe — billing ──────────────────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_replace_me
# Para dev local: stripe listen --forward-to localhost:3001/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me

# ── Observabilidad ────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
