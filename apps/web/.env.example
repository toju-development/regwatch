# apps/web env vars — composes core (.env at repo root) + web slice.
# Spec: auth-foundation § config — createWebEnv().

NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth canonical URL (optional in dev — NextAuth infers from request).
# AUTH_URL=http://localhost:3000

# Google OAuth (optional unless EMAIL_TRANSPORT=resend / real provider used).
# Operator decision: dev/CI uses fake-google; provision real client in deploy slice.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Resend Magic Link transport (optional unless EMAIL_TRANSPORT=resend).
# AUTH_RESEND_KEY=
# AUTH_EMAIL_FROM=noreply@regwatch.local

# Email transport selector: 'memory' (dev/CI default) | 'resend' (prod).
EMAIL_TRANSPORT=memory

# Mount the credentials-based fake-google provider at runtime.
# '1' = mounted (dev/CI default), '0' = real Google only.
AUTH_FAKE_GOOGLE=1
