# ── Base de datos ─────────────────────────────────────────────────────────────
# Mismo valor que apps/api
DATABASE_URL=postgresql://postgres:root@localhost:5432/regwatch_dev

# ── Auth — secreto compartido ─────────────────────────────────────────────────
# Mínimo 32 chars. Mismo valor que apps/api. Generar: openssl rand -base64 32
AUTH_SECRET=dev-auth-secret-local-replace-in-production-32c

# ── URLs internas ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001
# AUTH_URL=https://app.regwatch.com   # opcional en dev, requerido en prod

# ── Auth — proveedores ────────────────────────────────────────────────────────
# Fake Google (dev/CI). 1=habilitado, 0=deshabilitado
AUTH_FAKE_GOOGLE=1

# Google OAuth real — requerido en prod, opcional en dev con AUTH_FAKE_GOOGLE=1
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
# AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=GOCSPX-your-secret

# ── Magic link ────────────────────────────────────────────────────────────────
# memory = link en RAM, leer via GET /api/test/inbox/:email (dev/CI)
# resend = envío real (requiere AUTH_RESEND_KEY + AUTH_EMAIL_FROM)
EMAIL_TRANSPORT=memory

# Requeridas cuando EMAIL_TRANSPORT=resend
# Obtener API key en: https://resend.com → API Keys
# AUTH_RESEND_KEY=re_your_api_key
# AUTH_EMAIL_FROM=onboarding@resend.dev

# ── Registro y control de acceso ──────────────────────────────────────────────
# 0=solo invitados (default MVP), 1=registro público abierto
REGISTRATION_ENABLED=0
# Lista de emails permitidos cuando REGISTRATION_ENABLED=0 (separados por coma)
# INVITED_EMAILS=admin@empresa.com,dev@empresa.com

# ── Microsoft Entra ID (opcional) ─────────────────────────────────────────────
# Las tres vars deben estar todas presentes o todas ausentes
# AUTH_MICROSOFT_ENTRA_ID=your-client-id
# AUTH_MICROSOFT_ENTRA_SECRET=your-client-secret
# AUTH_MICROSOFT_ENTRA_TENANT_ID=common
# AUTH_FAKE_ENTRA=true   # dev/CI únicamente

# ── Stripe — billing (opcional, requerido en POST-9) ──────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_PRO_PRICE_ID=price_your_id
