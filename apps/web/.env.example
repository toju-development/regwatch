# apps/web env vars — composes core (.env at repo root) + web slice.
# Spec: auth-foundation § config — createWebEnv().

NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side base URL for apps/api used by PROXY route handlers under
# /api/org/* (see engram regwatch/decisions/org-membership-proxy-mode).
# Server-only — browser never reads this value (no NEXT_PUBLIC_ prefix).
API_URL=http://localhost:3001

# NextAuth canonical URL (optional in dev — NextAuth infers from request).
# AUTH_URL=http://localhost:3000

# Google OAuth (optional unless EMAIL_TRANSPORT=resend / real provider used).
# Operator decision: dev/CI uses fake-google; provision real client in deploy slice.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Resend Magic Link transport (optional unless EMAIL_TRANSPORT=resend).
# AUTH_RESEND_KEY=
# AUTH_EMAIL_FROM=noreply@regwatch.local

# Email transport selector: 'memory' (dev/CI default) | 'resend' (prod).
EMAIL_TRANSPORT=memory

# Mount the credentials-based fake-google provider at runtime.
# '1' = mounted (dev/CI default), '0' = real Google only.
AUTH_FAKE_GOOGLE=1

# ── Microsoft Entra ID / Azure AD (optional — sdd/auth-ms-entra) ────────────
# Enterprise SSO via Microsoft accounts. Feature is OFF by default; the app
# starts normally without these vars set.
#
# Prerequisites:
#   1. Create an Azure App Registration at https://portal.azure.com
#   2. Add redirect URI: https://<your-domain>/api/auth/callback/microsoft-entra-id
#   3. Copy the Application (client) ID and a Client Secret below.
#
# AUTH_MICROSOFT_TENANT_ID — use "common" for multi-tenant / personal accounts,
# or your specific tenant GUID to restrict to a single Azure AD directory.
# The app constructs the OIDC issuer URL as:
#   https://login.microsoftonline.com/<AUTH_MICROSOFT_ENTRA_TENANT_ID>/v2.0/
#
# All three vars must be set together or all left unset. Setting only one or
# two will throw an error at startup (INV-ENTRA-1).
#
# AUTH_MICROSOFT_ENTRA_ID=<Application (client) ID>
# AUTH_MICROSOFT_ENTRA_SECRET=<Client secret value>
# AUTH_MICROSOFT_ENTRA_TENANT_ID=common

# Dev-only fake Entra Credentials provider (same pattern as AUTH_FAKE_GOOGLE).
# Set to 'true' in dev/CI to enable. Do NOT set in production.
# AUTH_FAKE_ENTRA=true
