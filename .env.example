# Core env vars — required by every RegWatch app (api, scanner, web).
# Spec: auth-foundation § config — Per-app env slices.

# Postgres connection string (required).
DATABASE_URL=postgresql://regwatch:regwatch@localhost:5432/regwatch

# Node environment (development | test | production). Defaults to development.
NODE_ENV=development

# Shared HMAC secret for JWT signing/verification across apps/web and apps/api.
# Generate locally with: openssl rand -base64 32
# MUST be at least 32 characters.
AUTH_SECRET=replace-me-with-32-chars-min-secret-please

# Optional JWT issuer / audience claims (recommended values shown).
# When set, apps/web signs with iss/aud and apps/api enforces them.
# JWT_ISSUER=regwatch-web
# JWT_AUDIENCE=regwatch-api

# Manual ingestion (sdd/manual-ingestion MVP-7)
# Base URL of apps/scanner HTTP listener (ADR-7).
SCANNER_INTERNAL_URL=http://localhost:3002
# Shared secret for apps/api → apps/scanner internal calls (ADR-8).
# Generate: openssl rand -base64 32
SCANNER_INTERNAL_SECRET=replace-me-with-a-strong-secret
# Feature flag: set to 'true' to enable POST /ingest/manual (ADR-7).
MANUAL_INGEST_ENABLED=false
