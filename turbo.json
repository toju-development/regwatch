{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@regwatch/db#db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": ["SKIP_ENV_VALIDATION"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@regwatch/db#db:generate"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "@regwatch/db#db:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "@regwatch/db#db:generate"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@regwatch/db#db:generate": {
      "outputs": ["src/generated/**"],
      "cache": true
    },
    "@regwatch/db#db:migrate": {
      "cache": false,
      "persistent": false
    },
    "clean": {
      "cache": false
    }
  }
}
