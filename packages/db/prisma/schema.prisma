generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

// Scanner enums (sdd/scanner-vertical-ar/design ADR-7, migration #7).
// `AlertSource` is append-only — MVP-13 will add CNBV_MX_*, SBS_PE_*, BR_BCB_*,
// CL_CMF_*. PG enum extension is cheap (no `ALTER TYPE … RENAME`).
enum AlertSource {
  BCRA_COMUNICADOS_A
  BCRA_COMUNICADOS_B
  BCRA_COMUNICADOS_C
  CNV_RESOLUCIONES_GENERALES
}

// MVP-6 amendment (B1.1 / sdd/classifier-and-writer spec P1): enum will be
// reshaped in migration #9 to 5-bucket: UNKNOWN | LOW | MEDIUM | HIGH | CRITICAL.
// INFO is removed; LOW replaces it for low-impact findings. CRITICAL added for
// systemic/sanctions-level findings. Alert table confirmed empty before apply.
enum Severity {
  UNKNOWN
  INFO
  MEDIUM
  HIGH
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  // Cap-enforcement short-circuit (R-5). Name "EXCEEDED" wins over "REACHED"
  // because the gate fires AFTER the cap was crossed by the previous run.
  SKIPPED_CAP_EXCEEDED
}

model Organization {
  id             String       @id @default(cuid())
  slug           String       @unique @db.VarChar(64)
  name           String       @db.VarChar(120)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]
  invitations    Invitation[]
  personalOfUser User?        @relation("PersonalOrg")
  settings       Settings?
  alerts         Alert[]
  scanLogs       ScanLog[]
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique @db.VarChar(254)
  name               String?       @db.VarChar(120)
  emailVerified      DateTime?
  image              String?       @db.VarChar(2048)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  personalOrgId      String?       @unique
  personalOrg        Organization? @relation("PersonalOrg", fields: [personalOrgId], references: [id], onDelete: SetNull)
  memberships        Membership[]
  accounts           Account[]
  // Invitations issued by this user. SetNull on delete so historical
  // audit rows survive while not blocking user removal (sdd/org-invitations D1, R-Invitation-Schema scenario "invitedBy SetNull on user deletion").
  invitationsIssued  Invitation[]  @relation("InvitedBy")
  // R-User-Memberships-Version (sdd/org-members) — bumped in same `$transaction`
  // as every Membership write so JWTs carrying a stale `mv` claim are detected
  // by `MembershipFreshnessGuard`. Additive default 0 — pre-existing rows get 0.
  membershipsVersion Int           @default(0) @map("memberships_version")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @db.VarChar(254)
  role           Role
  token          String       @unique @db.VarChar(64)
  // Issuer of the invitation. Nullable so user deletions don't block the
  // invitation history (onDelete: SetNull). Audit-friendly default.
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  // Soft-revoke marker. NULL == not revoked. Status is COMPUTED via
  // computeInvitationStatus() — REVOKED beats EXPIRED. Never overwritten
  // on idempotent revoke (preserves original audit timestamp).
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
}

// Per-Organization compliance settings (jurisdictions registry selection +
// scan cadence). 1:1 with `Organization` (lazy-created by
// `SettingsService.getOrCreate` on first read; see
// sdd/jurisdictions-config/design D9, D15).
//
// `jurisdictions` is a Postgres `jsonb` column validated app-side by
// `SettingsJurisdictionsSchema` from `@regwatch/types/settings` (design D6).
// `scanSchedule` and `scanDay` are TS-only enum strings — no Postgres ENUM,
// to keep cadence additions schema-migration-free (design D3). Defaults are
// TS-side in `DEFAULT_SETTINGS` (design §4 — registry-driven).
model Settings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jurisdictions Json
  scanSchedule  String @default("weekly")
  scanDay       String @default("mon")
  scanHour      Int    @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Scanner domain (sdd/scanner-vertical-ar — MVP-5) ──────────────────────
//
// Sole writer: `apps/scanner` ScanService.runScan(orgId) inside a single
// `prisma.$transaction` (INV-SP-1, R-3). organizationId comes ONLY from the
// trusted `orgId` parameter — NEVER from LLM agent output (INV-SP-2).

// Discovered regulatory finding. Composite unique on
// (organizationId, sourceUrlHash) is the dedup gate (R-4, INV-DB-1) — same
// finding can exist in multiple orgs (R-4 cross-org scenario).
model Alert {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  source        AlertSource
  sourceUrl     String      @db.VarChar(2048)
  /// sha256 hex of normalizeUrl(sourceUrl). 64 chars. Never null.
  sourceUrlHash String      @db.VarChar(64)
  title         String      @db.VarChar(500)
  /// Optional — populated by LLM finding; nullable for forward-compat.
  summary       String?     @db.Text
  /// Populated by future fetch step (MVP-6/8). Null in MVP-5.
  fullContent   String?     @db.Text
  publishedAt   DateTime?
  detectedAt    DateTime    @default(now())
  severity      Severity    @default(UNKNOWN)
  /// Populated by MVP-6 classifier. Null in MVP-5.
  regulationId  String?

  scanLogId String?
  scanLog   ScanLog? @relation(fields: [scanLogId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([organizationId, sourceUrlHash])
  @@index([organizationId, detectedAt])
  @@index([organizationId, source])
}

// One row per scan attempt (cron tick or manual trigger). `costUsd` precision
// `Decimal(10,6)` is REQUIRED by spec R-14 + design ADR-7: Gemini 2.5 Flash
// per-token costs land in the 1e-6 USD range (input $0.30/1M = $3e-7/token);
// the original (10,4) precision (B1 / migration #7) truncated those values
// silently and was corrected by migration #8 (`fix_scanlog_costusd_precision`,
// B4.0 of MVP-5). Max value 9,999.999999 — still safely above the $10 cap.
//
// Index `(organizationId, startedAt)` powers the monthly-sum query in
// `getMonthlyUsage` (R-11, R-14, INV-UT-1).
model ScanLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Jurisdiction code, e.g. `'AR'`. String for forward-compat (MVP-13).
  jurisdiction String      @db.VarChar(8)
  /// Optional source URL when the scan was scoped to a single feed.
  sourceUrl    String?     @db.VarChar(2048)
  status       ScanStatus
  errorMsg     String?     @db.Text

  /// Sum of input + output tokens (denormalized for fast SUM aggregation).
  tokensUsed Int     @default(0)
  /// USD cost. ALWAYS Prisma.Decimal — never JS Number (INV-SP-3).
  /// Precision (10,6) per spec R-14 + design ADR-7 — covers Gemini 2.5
  /// Flash sub-cent token costs (1e-6 USD/token range) without truncation.
  costUsd    Decimal @default(0) @db.Decimal(10, 6)

  alertsFound Int @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  alerts Alert[]

  @@index([organizationId, startedAt])
  @@index([organizationId, status])
}
