generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

// Scanner enums (sdd/scanner-vertical-ar/design ADR-7, migration #7).
// `AlertSource` is append-only — MVP-13 will add CNBV_MX_*, SBS_PE_*, BR_BCB_*,
// CL_CMF_*. PG enum extension is cheap (no `ALTER TYPE … RENAME`).
enum AlertSource {
  BCRA_COMUNICADOS_A
  BCRA_COMUNICADOS_B
  BCRA_COMUNICADOS_C
  CNV_RESOLUCIONES_GENERALES
  /// MVP-7 manual ingestion (migration #11, sdd/manual-ingestion R-SCHEMA-1)
  MANUAL
}

// MVP-6 migration #9 (sdd/classifier-and-writer spec P1, B1.3):
// Reshaped from 4-bucket (UNKNOWN/INFO/MEDIUM/HIGH) to 5-bucket.
// INFO dropped; LOW added for low-impact findings; CRITICAL added for
// systemic/sanctions-level findings. Alert table was empty before apply.
// Classifier emits LOW|MEDIUM|HIGH|CRITICAL on success; UNKNOWN is
// failure-only (enrichmentStatus=CLASSIFY_FAILED path).
enum Severity {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  // Cap-enforcement short-circuit (R-5). Name "EXCEEDED" wins over "REACHED"
  // because the gate fires AFTER the cap was crossed by the previous run.
  SKIPPED_CAP_EXCEEDED
}

// ─── Enrichment domain enums (sdd/classifier-and-writer — MVP-6, migration #9) ─

// 20-value regulatory taxonomy (proposal D2). Values are SCREAMING_SNAKE_CASE,
// English. Derived dynamically from Prisma at runtime and injected as a prompt
// PARAMETER — NEVER hardcoded in prompt text (ADR-4, INV-AE-4, defuses #798).
// OTHER is the safety net when no topic clearly fits.
// Taxonomy is append-only; new values require a migration (acceptable — topics
// are governance-controlled, not user-input). MVP-13 may migrate to a table.
enum AlertTopic {
  FX
  AML
  KYC_ONBOARDING
  CAPITAL_REQUIREMENTS
  OPERATIONAL_RISK
  CYBERSECURITY
  REPORTING
  CAPITAL_MARKETS
  E_MONEY
  ACQUIRING
  REMITTANCES
  BILL_PAYMENTS
  QR_PAYMENTS
  VIRTUAL_ASSETS
  LENDING_CREDIT
  OPEN_FINANCE
  CONSUMER_PROTECTION
  INSURANCE
  DATA_PROTECTION
  OTHER
}

// Per-alert enrichment pipeline state machine (R-8).
// Terminal success: COMPLETED. Terminal failure: CLASSIFY_FAILED, WRITE_FAILED,
// SKIPPED_CAP_EXCEEDED, SKIPPED_IRRELEVANT.
// Idempotency rule (ADR-9): re-run on {PENDING, CLASSIFY_FAILED, WRITE_FAILED,
// SKIPPED_CAP_EXCEEDED}; skip on {CLASSIFIED, WRITTEN, COMPLETED, SKIPPED_IRRELEVANT}.
enum EnrichmentStatus {
  PENDING
  CLASSIFIED
  WRITTEN
  COMPLETED
  CLASSIFY_FAILED
  WRITE_FAILED
  SKIPPED_CAP_EXCEEDED
  SKIPPED_IRRELEVANT
}

model Organization {
  id             String          @id @default(cuid())
  slug           String          @unique @db.VarChar(64)
  name           String          @db.VarChar(120)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  invitations    Invitation[]
  personalOfUser User?           @relation("PersonalOrg")
  settings       Settings?
  alerts         Alert[]
  scanLogs       ScanLog[]
  enrichmentLogs EnrichmentLog[]
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique @db.VarChar(254)
  name               String?       @db.VarChar(120)
  emailVerified      DateTime?
  image              String?       @db.VarChar(2048)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  personalOrgId      String?       @unique
  personalOrg        Organization? @relation("PersonalOrg", fields: [personalOrgId], references: [id], onDelete: SetNull)
  memberships        Membership[]
  accounts           Account[]
  // Invitations issued by this user. SetNull on delete so historical
  // audit rows survive while not blocking user removal (sdd/org-invitations D1, R-Invitation-Schema scenario "invitedBy SetNull on user deletion").
  invitationsIssued  Invitation[]  @relation("InvitedBy")
  // R-User-Memberships-Version (sdd/org-members) — bumped in same `$transaction`
  // as every Membership write so JWTs carrying a stale `mv` claim are detected
  // by `MembershipFreshnessGuard`. Additive default 0 — pre-existing rows get 0.
  membershipsVersion Int           @default(0) @map("memberships_version")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @db.VarChar(254)
  role           Role
  token          String       @unique @db.VarChar(64)
  // Issuer of the invitation. Nullable so user deletions don't block the
  // invitation history (onDelete: SetNull). Audit-friendly default.
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  // Soft-revoke marker. NULL == not revoked. Status is COMPUTED via
  // computeInvitationStatus() — REVOKED beats EXPIRED. Never overwritten
  // on idempotent revoke (preserves original audit timestamp).
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
}

// Per-Organization compliance settings (jurisdictions registry selection +
// scan cadence). 1:1 with `Organization` (lazy-created by
// `SettingsService.getOrCreate` on first read; see
// sdd/jurisdictions-config/design D9, D15).
//
// `jurisdictions` is a Postgres `jsonb` column validated app-side by
// `SettingsJurisdictionsSchema` from `@regwatch/types/settings` (design D6).
// `scanSchedule` and `scanDay` are TS-only enum strings — no Postgres ENUM,
// to keep cadence additions schema-migration-free (design D3). Defaults are
// TS-side in `DEFAULT_SETTINGS` (design §4 — registry-driven).
model Settings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jurisdictions Json
  scanSchedule  String @default("weekly")
  scanDay       String @default("mon")
  scanHour      Int    @default(8)

  // MVP-6 (migration #9): nullable output-language override for Writer.
  // Accepts 'es' | 'en' | 'pt' | null (null = use jurisdiction default).
  // Zod-validated on PUT by SettingsService. R-Settings-OutputLanguage.
  outputLanguage String?

  // MVP-6 (migration #10): last time an alert was skipped due to cap exceeded.
  // Set by EnrichmentService.persistCapExceeded (R-5, R-Usage-LastSkipped).
  // Null until the first cap-skip event occurs.
  lastSkippedCapAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Scanner domain (sdd/scanner-vertical-ar — MVP-5) ──────────────────────
//
// Sole writer: `apps/scanner` ScanService.runScan(orgId) inside a single
// `prisma.$transaction` (INV-SP-1, R-3). organizationId comes ONLY from the
// trusted `orgId` parameter — NEVER from LLM agent output (INV-SP-2).

// Discovered regulatory finding. Composite unique on
// (organizationId, sourceUrlHash) is the dedup gate (R-4, INV-DB-1) — same
// finding can exist in multiple orgs (R-4 cross-org scenario).
model Alert {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  source        AlertSource
  sourceUrl     String      @db.VarChar(2048)
  /// sha256 hex of normalizeUrl(sourceUrl). 64 chars. Never null.
  sourceUrlHash String      @db.VarChar(64)
  title         String      @db.VarChar(500)
  /// Optional — populated by LLM finding; nullable for forward-compat.
  summary       String?     @db.Text
  /// Populated by future fetch step (MVP-8). Null in MVP-5/6.
  fullContent   String?     @db.Text
  publishedAt   DateTime?
  detectedAt    DateTime    @default(now())
  severity      Severity    @default(UNKNOWN)
  /// Populated by MVP-6 classifier. Null in MVP-5.
  regulationId  String?

  /// MVP-7: jurisdiction for manual alerts (migration #11, ADR-5). Null for scanner alerts
  /// (those resolve via scanLog.jurisdiction). Required at creation for MANUAL source.
  jurisdiction String? @db.VarChar(8)

  scanLogId String?
  scanLog   ScanLog? @relation(fields: [scanLogId], references: [id], onDelete: SetNull)

  // ── MVP-6 enrichment columns (migration #9, R-AlertEnrichment-Schema) ──
  // All nullable — pre-existing rows keep null, enrichmentStatus=PENDING.
  // Sole writer: EnrichmentService.enrichAlertsForScan (INV-AE-1).

  /// Regulatory topic bucket. Null until Classifier runs.
  topic             AlertTopic?
  /// Classifier relevance score 0-100 (Int, ADR-2 / spec P2). Null until classified.
  relevanceScore    Int?             @default(0)
  /// true = relevant for this org (Writer will run). false = SKIPPED_IRRELEVANT.
  relevant          Boolean          @default(true)
  /// Timestamp when Classifier completed successfully.
  classifiedAt      DateTime?
  /// Writer output — human-readable summary for compliance team.
  executiveSummary  String?          @db.Text
  /// Writer output — actionable items for this org.
  whatChangesForYou String?          @db.Text
  /// Writer output — verbatim citation strings from Alert.summary.
  citations         Json?
  /// Timestamp when Writer completed successfully.
  writtenAt         DateTime?
  /// Current enrichment pipeline state (R-8, ADR-9).
  enrichmentStatus  EnrichmentStatus @default(PENDING)
  /// Error detail when enrichmentStatus ∈ {CLASSIFY_FAILED, WRITE_FAILED}.
  enrichmentError   String?          @db.Text

  enrichmentLogs EnrichmentLog[]

  createdAt DateTime @default(now())

  @@unique([organizationId, sourceUrlHash])
  @@index([organizationId, detectedAt])
  @@index([organizationId, source])
  @@index([organizationId, enrichmentStatus])
}

// One row per scan attempt (cron tick or manual trigger). `costUsd` precision
// `Decimal(10,6)` is REQUIRED by spec R-14 + design ADR-7: Gemini 2.5 Flash
// per-token costs land in the 1e-6 USD range (input $0.30/1M = $3e-7/token);
// the original (10,4) precision (B1 / migration #7) truncated those values
// silently and was corrected by migration #8 (`fix_scanlog_costusd_precision`,
// B4.0 of MVP-5). Max value 9,999.999999 — still safely above the $10 cap.
//
// Index `(organizationId, startedAt)` powers the monthly-sum query in
// `getMonthlyUsage` (R-11, R-14, INV-UT-1).
model ScanLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Jurisdiction code, e.g. `'AR'`. String for forward-compat (MVP-13).
  jurisdiction String     @db.VarChar(8)
  /// Optional source URL when the scan was scoped to a single feed.
  sourceUrl    String?    @db.VarChar(2048)
  status       ScanStatus
  errorMsg     String?    @db.Text

  /// Sum of input + output tokens (denormalized for fast SUM aggregation).
  tokensUsed Int     @default(0)
  /// USD cost. ALWAYS Prisma.Decimal — never JS Number (INV-SP-3).
  /// Precision (10,6) per spec R-14 + design ADR-7 — covers Gemini 2.5
  /// Flash sub-cent token costs (1e-6 USD/token range) without truncation.
  costUsd    Decimal @default(0) @db.Decimal(10, 6)

  alertsFound Int @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  alerts Alert[]

  @@index([organizationId, startedAt])
  @@index([organizationId, status])
}

// ─── Enrichment domain (sdd/classifier-and-writer — MVP-6, migration #9) ───
//
// One row per agent invocation attempt (classifier OR writer) per Alert.
// Sole writer: EnrichmentService (in apps/scanner).
// costUsd Decimal(10,6) — same precision rationale as ScanLog.costUsd.
// Index (organizationId, createdAt) powers getMonthlyUsage enrichment sum (R-Usage-3).
// Index (alertId) powers per-alert log queries.
model EnrichmentLog {
  id             String           @id @default(cuid())
  organizationId String
  alertId        String
  /// Which agent produced this log: 'classifier' | 'writer'.
  agent          String           @db.VarChar(20)
  tokensInput    Int              @default(0)
  tokensOutput   Int              @default(0)
  /// USD cost for this invocation. 0 for skipped/failed-before-call rows.
  costUsd        Decimal          @default(0) @db.Decimal(10, 6)
  status         EnrichmentStatus
  errorMsg       String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alert        Alert        @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([alertId])
}
